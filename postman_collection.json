{
	"info": {
		"name": "Nội Thất E-Commerce API",
		"description": "Full API collection for Node.js BFF Backend - 15 tables, ~125+ endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000/api" },
		{ "key": "token", "value": "" },
		{ "key": "adminToken", "value": "" }
	],
	"item": [
		{
			"name": "🔐 AUTH",
			"item": [
				{
					"name": "Login (Unified — tự xác định role)",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"var res = pm.response.json();",
								"if (res.data && res.data.token) {",
								"  var scope = res.data.scope;",
								"  if (scope === 'ROLE_CUSTOMER') {",
								"    pm.collectionVariables.set('token', res.data.token);",
								"    console.log('✅ Saved as Customer token');",
								"  } else {",
								"    pm.collectionVariables.set('adminToken', res.data.token);",
								"    console.log('✅ Saved as Admin/Staff token, scope:', scope);",
								"  }",
								"}"
							]
						}
					}],
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/auth/login",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\"\n}" }
					}
				}
			]
		},
		{
			"name": "👤 CUSTOMER",
